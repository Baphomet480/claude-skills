{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic OS Tasks Queue",
  "type": "object",
  "properties": {
    "pending": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    },
    "in_progress": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    },
    "completed": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "assigned_skill": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" },
        "result": { "type": "string" }
      },
      "required": ["id", "description", "created_at"]
    }
  }
}
