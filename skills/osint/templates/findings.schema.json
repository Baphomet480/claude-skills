{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genericservice.app/schemas/osint-findings.schema.json",
  "title": "OSINT Findings",
  "description": "Structured sidecar for an OSINT dossier. Every claim in the markdown report should map to a finding here, with explicit confidence grading and source list.",
  "type": "object",
  "required": ["target", "investigation", "findings"],
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "object",
      "required": ["slug", "type", "display_name"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "kebab-case identifier safe for filenames"
        },
        "type": {
          "type": "string",
          "enum": ["person", "company", "b2b-account", "domain", "dd-subject", "threat-entity"]
        },
        "display_name": { "type": "string" },
        "discriminator": {
          "type": "string",
          "description": "What disambiguates this target from namesakes (employer, location, role, registry id, etc.)"
        },
        "primary_identifier_url": {
          "type": "string",
          "format": "uri",
          "description": "Authoritative URL the target uniquely resolves to (LinkedIn URL, registry record, canonical website, etc.)"
        },
        "explicitly_not": {
          "type": "array",
          "description": "Named entities that share the name and were excluded.",
          "items": {
            "type": "object",
            "required": ["display_name", "reason"],
            "additionalProperties": false,
            "properties": {
              "display_name": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },

    "investigation": {
      "type": "object",
      "required": ["depth", "started_at", "scope", "workflow"],
      "additionalProperties": false,
      "properties": {
        "depth": {
          "type": "string",
          "enum": ["quick", "standard", "deep"]
        },
        "started_at":   { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "scope": {
          "type": "string",
          "description": "One-sentence scope statement: 'Researching X for Y using public sources.'"
        },
        "workflow": {
          "type": "string",
          "enum": ["person", "company", "b2b-account", "domain", "due-diligence"]
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g. web_search, web_fetch, dig, whois, crt.sh, github_search"
        },
        "searches_run": {
          "type": "integer",
          "minimum": 0
        },
        "investigator": { "type": "string" }
      }
    },

    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "confidence", "sources"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F[0-9]+$",
            "description": "Stable id within the dossier, e.g. F001"
          },
          "claim": {
            "type": "string",
            "description": "One sentence, factual, no editorializing."
          },
          "confidence": {
            "type": "string",
            "enum": ["A", "B", "C", "D"],
            "description": "A=3+ independent + 1 primary; B=2 independent; C=1 source; D=inferred."
          },
          "category": {
            "type": "string",
            "description": "Workflow-specific grouping, e.g. 'identity', 'leadership', 'tech-stack', 'litigation'"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["url", "type", "accessed_at"],
              "additionalProperties": false,
              "properties": {
                "url":       { "type": "string", "format": "uri" },
                "type": {
                  "type": "string",
                  "enum": [
                    "primary",
                    "press",
                    "registry",
                    "regulatory",
                    "court",
                    "self-published",
                    "aggregator",
                    "third-party",
                    "other"
                  ]
                },
                "publisher":   { "type": "string" },
                "published_at":{ "type": "string", "format": "date" },
                "accessed_at": { "type": "string", "format": "date-time" },
                "note":        { "type": "string" }
              }
            }
          },
          "extracted_at": { "type": "string", "format": "date-time" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supersedes": {
            "type": "string",
            "pattern": "^F[0-9]+$",
            "description": "If this finding replaces an earlier one (e.g., upgraded confidence after new source), reference its id."
          }
        }
      }
    },

    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question"],
        "additionalProperties": false,
        "properties": {
          "question":        { "type": "string" },
          "why_unanswered":  { "type": "string" },
          "would_resolve_with": { "type": "string" }
        }
      }
    },

    "decline_log": {
      "type": "array",
      "description": "Things the investigator explicitly declined to do, with reason. Keeps the ethics layer auditable.",
      "items": {
        "type": "object",
        "required": ["action", "reason"],
        "additionalProperties": false,
        "properties": {
          "action": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
